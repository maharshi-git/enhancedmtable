<mvc:View controllerName="customtableapp.controller.Main"
    xmlns:mvc="sap.ui.core.mvc" displayBlock="true"
    xmlns="sap.m"
    xmlns:custom="customtableapp.control">
    <Page title="Enhanced Table App" class="sapUiContentPadding">
        <content>
        <VBox>
        
        <VBox width="70%">
            <custom:EnhancedTable id="myEnhancedTable" data="{/tableData}" visibleRows="10" />
        </VBox>
        </VBox>
        </content>
    </Page>
</mvc:View>
